{
  "name": "contentrx-app",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "author": "Robert Ballard",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "check:no-dup-files": "bash scripts/check_no_dup_files.sh",
    "fetch:substrate": "bash scripts/fetch-substrate.sh",
    "predev": "npm run check:no-dup-files && npm run fetch:substrate",
    "dev": "next dev",
    "prebuild": "npm run check:no-dup-files && npm run fetch:substrate",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run check:no-dup-files",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "extract-strings": "tsx scripts/extract-customer-strings.ts",
    "lint:copy": "tsx scripts/lint-customer-strings.ts",
    "check:engine": "tsx scripts/check-copy-with-engine.ts",
    "reset-usage": "dotenv -e .env.local -- tsx scripts/reset-usage.ts",
    "export-corpus": "dotenv -e .env.local -- tsx scripts/export-corpus.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.3",
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/nextjs": "^10.49.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "next": "15.5.15",
    "postgres": "^3.4.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "svix": "^1.91.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}

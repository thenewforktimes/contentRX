{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "regions": ["iad1"],
  "functions": {
    "api/evaluate.py": {
      "includeFiles": "src/content_checker/**",
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/agent-run",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/renewal-reminder",
      "schedule": "0 10 * * *"
    }
  ]
}

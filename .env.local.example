# -- Database (Supabase Postgres) --
# Connection string from Supabase project settings > Database > Connection Pooling
# Use the "Transaction" mode pooler URL for serverless compatibility
DATABASE_URL=

# -- Clerk (auth) --
# From https://dashboard.clerk.com > API Keys
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# From Clerk dashboard > Webhooks > after creating the /api/webhooks/clerk endpoint
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -- Anthropic (evaluation engine) --
# Set a $300 monthly cap in the Anthropic console before using in production
ANTHROPIC_API_KEY=

# -- Upstash Redis (rate limiting) --
# TWO valid naming schemes, src/lib/ratelimit.ts checks both:
#   1. Native Upstash (if you created the DB directly at console.upstash.com):
#        UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
#   2. Vercel Marketplace Upstash integration (auto-provisioned via
#      Vercel dashboard Storage tab) — uses legacy KV_* names:
#        KV_REST_API_URL, KV_REST_API_TOKEN
# Either set works. Vercel Marketplace is simpler; leave these blank if
# you went that route (Vercel will inject KV_REST_API_* automatically).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -- Stripe (billing) --
# Test keys for dev, live keys for prod
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe price IDs (created in dashboard after Session 8)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=

# -- Resend (email) --
# From https://resend.com > API Keys
RESEND_API_KEY=
# Verified sender domain
EMAIL_FROM=hello@contentrx.io
# Where founder-only operational alerts go (cost-margin breaches,
# stripe-overage-meter push failures, cost-pause triggers). Falls
# back to EMAIL_FROM (hello@contentrx.io) when unset, but a real
# inbox you read should land here in production.
FOUNDER_EMAIL=

# -- Sentry (errors) --
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -- Plausible (analytics) --
# Domain you registered the site under at plausible.io (e.g. content-rx.vercel.app)
# Leave blank to skip analytics in dev / preview.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# -- App --
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret between /api/check (TS, public) and /api/evaluate (Python, internal).
# Same value in both runtimes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
INTERNAL_EVAL_SECRET=

# Optional override for where /api/check finds the Python evaluator.
# Leave blank in production; Vercel co-locates both runtimes.
# In dev you may need to point at a separate Python dev server, e.g.
# http://localhost:8000.
INTERNAL_EVAL_URL=

# Used for AES-256 encryption of stored Ditto API keys (Session 18)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DITTO_ENCRYPTION_KEY=

# -- Cron / admin server-to-server auth --
# Required by /api/cron/* and /api/admin/refinement-signals and
# /api/preferences/export. Vercel Cron passes "Authorization: Bearer
# $CRON_SECRET" automatically; ad-hoc curl/admin tooling does the same.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=

# Comma-separated list of Clerk user IDs allowed to access admin pages
# and the /api/admin/* surface. Empty = no admins (admin UI fails closed).
CONTENTRX_ADMIN_CLERK_IDS=

# Override the canonical docs base URL surfaced in violation `docs_url`
# fields. Defaults to https://docs.contentrx.io. Override only for
# preview/staging docs sites.
# (NOTE: `docs_url` is removed from the public Violation envelope in
# schema_version 2.0.0 per the 2026-04-25 private-taxonomy pivot. This
# entry will be removed when the schema cutover lands.)
CONTENTRX_DOCS_URL=

# -- Feature flags --
# PUBLIC_TAXONOMY controls whether `standard_id` and `rule_version`
# populate on user-facing surfaces. Default `false` everywhere; the
# 2026-04-25 private-taxonomy pivot ADR locks the default. Code paths
# gated by it stay in the codebase even when off — they are
# reversibility insurance, not dead code. Don't delete them.
#
# Truthy values (case-insensitive): true, 1, yes, on. Anything else
# (including empty) is falsy.
#
# Reads happen at runtime via:
#   src/content_checker/config.py::is_public_taxonomy_enabled (Python)
#   src/lib/feature-flags.ts::isPublicTaxonomyEnabled (TS)
#
# CI exercises both modes; see .github/workflows/public_taxonomy_smoke.yml.
PUBLIC_TAXONOMY=false

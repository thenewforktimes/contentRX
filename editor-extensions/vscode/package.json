{
  "name": "contentrx",
  "displayName": "ContentRX",
  "description": "Inline content-design review in VS Code and Cursor. Staff-level UX-writing feedback on every string as you type.",
  "version": "0.1.0",
  "publisher": "ContentRX",
  "license": "MIT",
  "homepage": "https://contentrx.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/thenewforktimes/contentRX.git",
    "directory": "editor-extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/thenewforktimes/contentRX/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "content",
    "ux-writing",
    "copy",
    "linter",
    "language-server",
    "contentrx"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "contributes": {
    "commands": [
      {
        "command": "contentrx.setApiKey",
        "title": "ContentRX: Set API key",
        "category": "ContentRX"
      },
      {
        "command": "contentrx.clearApiKey",
        "title": "ContentRX: Clear stored API key",
        "category": "ContentRX"
      },
      {
        "command": "contentrx.restartServer",
        "title": "ContentRX: Restart language server",
        "category": "ContentRX"
      }
    ],
    "configuration": {
      "title": "ContentRX",
      "properties": {
        "contentrx.serverPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the contentrx-lsp executable. Leave blank to launch via `uvx contentrx-lsp`."
        },
        "contentrx.apiUrl": {
          "type": "string",
          "default": "",
          "description": "Override the ContentRX API base URL. Leave blank to use https://contentrx.io."
        },
        "contentrx.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP messages between the editor and the ContentRX server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/vscode": "^1.118.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.0"
  }
}
